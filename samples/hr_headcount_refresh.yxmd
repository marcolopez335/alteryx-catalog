<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2023.1">
  <Properties>
    <MetaInfo>
      <Name>HR Headcount Refresh</Name>
      <Description>Refreshes headcount data from Workday API export, cleans department mappings, and outputs to HR reporting database.</Description>
      <Author>Mike Johnson</Author>
      <CreationDate>2025-01-10</CreationDate>
      <LastSavedDate>2026-03-01</LastSavedDate>
    </MetaInfo>
    <RuntimeProperties>
      <ModuleType>Standard</ModuleType>
    </RuntimeProperties>
    <Annotation DisplayMode="0">
      <DefaultAnnotationText>HR Headcount - Human Resources</DefaultAnnotationText>
    </Annotation>
  </Properties>
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="100" y="100" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <File RecordLimit="" FileFormat="0" SearchSubDirs="False">
            <ConnectionString>\\fileserver\hr\exports\workday_headcount.csv</ConnectionString>
          </File>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Input: Workday Export</Name>
          <DefaultAnnotationText>Workday Headcount CSV</DefaultAnnotationText>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxDbFileInput" />
    </Node>
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="100" y="250" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <File RecordLimit="" FileFormat="0" SearchSubDirs="False">
            <ConnectionString>\\fileserver\hr\reference\dept_mapping.xlsx</ConnectionString>
            <Table>Mappings$</Table>
          </File>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Input: Department Mapping</Name>
          <DefaultAnnotationText>Dept Mapping Excel</DefaultAnnotationText>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxDbFileInput" />
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="250" y="100" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Expression>[status] = "Active"</Expression>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Filter Active Employees</Name>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFilter" />
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Join.Join">
        <Position x="400" y="175" />
      </GuiSettings>
      <Properties>
        <Configuration joinByRecordPos="False">
          <JoinInfo connection="Left">
            <Field field="dept_code" />
          </JoinInfo>
          <JoinInfo connection="Right">
            <Field field="dept_code" />
          </JoinInfo>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Join Department Names</Name>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxJoin" />
    </Node>
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileOutput.DbFileOutput">
        <Position x="600" y="175" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <File FileFormat="19" MaxRecords="">
            <ConnectionString>odbc:DSN=HRDB;Trusted_Connection=Yes</ConnectionString>
            <Table>dbo.headcount_current</Table>
          </File>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Output: HR Database</Name>
          <DefaultAnnotationText>Write to HRDB</DefaultAnnotationText>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxDbFileOutput" />
    </Node>
  </Nodes>
  <Connections>
    <Connection>
      <Origin ToolID="1" Connection="Output" />
      <Destination ToolID="3" Connection="Input" />
    </Connection>
    <Connection>
      <Origin ToolID="3" Connection="True" />
      <Destination ToolID="4" Connection="Left" />
    </Connection>
    <Connection>
      <Origin ToolID="2" Connection="Output" />
      <Destination ToolID="4" Connection="Right" />
    </Connection>
    <Connection>
      <Origin ToolID="4" Connection="Join" />
      <Destination ToolID="5" Connection="Input" />
    </Connection>
  </Connections>
</AlteryxDocument>
